# Node
TZ=UTC
PORT=3333
# Use 0.0.0.0 in any container/PaaS (including Railway) so the server is
# reachable. "localhost" only binds the loopback interface.
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
# Generate with: node ace generate:key
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
# DB_CONNECTION selects the active connection from config/database.ts.
# Set to "postgres" or "mysql". Provide only the matching connection string.
DB_CONNECTION=postgres
# Postgres (Railway: ${{Postgres.DATABASE_URL}})
DATABASE_URL=
# MySQL (Railway: ${{MySQL.MYSQL_URL}})
MYSQL_URL=

# Queue
# Driver for @adonisjs/queue: "redis" (production), "database", or "sync"
# (runs jobs inline, no worker/Redis needed — handy for local dev).
QUEUE_DRIVER=redis

# Redis
# On Railway, map these to the Redis service (see DEPLOY.md).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
